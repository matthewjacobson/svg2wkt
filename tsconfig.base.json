{
  "compilerOptions": {
    "target": "ES2019",
    "lib": ["ES2019"],
    "rootDir": "src",
    "strict": true,
    "noUncheckedIndexedAccess": false,
    "declaration": false,
    "removeComments": false,
    "sourceMap": true,
    "newLine": "lf",
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"]
}
